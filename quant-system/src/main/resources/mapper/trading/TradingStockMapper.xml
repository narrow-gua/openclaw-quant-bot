<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quant.trading.system.mapper.trading.TradingStockMapper">

    <resultMap type="com.quant.trading.system.domain.trading.TradingStock" id="TradingStockResult">
        <id     property="stockId"       column="stock_id"         />
        <result property="symbol"        column="symbol"          />
        <result property="name"          column="name"            />
        <result property="type"          column="type"            />
        <result property="currentPrice"  column="current_price"  />
        <result property="targetPrice"   column="target_price"   />
        <result property="stopLossPrice" column="stop_loss_price"/>
        <result property="status"        column="status"         />
        <result property="remark"       column="remark"         />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"   />
    </resultMap>

    <sql id="selectTradingStockVo">
        select stock_id, symbol, name, type, current_price, target_price, stop_loss_price, status, remark, create_time, update_time
        from trading_stock
    </sql>

    <select id="selectTradingStockList" parameterType="com.quant.trading.system.domain.trading.TradingStock" resultMap="TradingStockResult">
        <include refid="selectTradingStockVo"/>
        <where>
            <if test="symbol != null and symbol != ''">
                AND symbol like concat('%', #{symbol}, '%')
            </if>
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectTradingStockById" parameterType="Long" resultMap="TradingStockResult">
        <include refid="selectTradingStockVo"/>
        where stock_id = #{stockId}
    </select>

    <select id="selectTradingStockBySymbol" parameterType="String" resultMap="TradingStockResult">
        <include refid="selectTradingStockVo"/>
        where symbol = #{symbol}
    </select>

    <insert id="insertTradingStock" parameterType="com.quant.trading.system.domain.trading.TradingStock" useGeneratedKeys="true" keyProperty="stockId">
        insert into trading_stock
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="symbol != null and symbol != ''">symbol,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="currentPrice != null">current_price,</if>
            <if test="targetPrice != null">target_price,</if>
            <if test="stopLossPrice != null">stop_loss_price,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="symbol != null and symbol != ''">#{symbol},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="currentPrice != null">#{currentPrice},</if>
            <if test="targetPrice != null">#{targetPrice},</if>
            <if test="stopLossPrice != null">#{stopLossPrice},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            now(),
        </trim>
    </insert>

    <update id="updateTradingStock" parameterType="com.quant.trading.system.domain.trading.TradingStock">
        update trading_stock
        <trim prefix="SET" suffixOverrides=",">
            <if test="symbol != null and symbol != ''">symbol = #{symbol},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="currentPrice != null">current_price = #{currentPrice},</if>
            <if test="targetPrice != null">target_price = #{targetPrice},</if>
            <if test="stopLossPrice != null">stop_loss_price = #{stopLossPrice},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now(),
        </trim>
        where stock_id = #{stockId}
    </update>

    <delete id="deleteTradingStockById" parameterType="Long">
        delete from trading_stock where stock_id = #{stockId}
    </delete>

    <delete id="deleteTradingStockByIds" parameterType="Long">
        delete from trading_stock where stock_id in
        <foreach item="stockId" collection="array" open="(" separator="," close=")">
            #{stockId}
        </foreach>
    </delete>

    <select id="checkSymbolUnique" parameterType="String" resultType="int">
        select count(1) from trading_stock where symbol = #{symbol}
    </select>

</mapper>
