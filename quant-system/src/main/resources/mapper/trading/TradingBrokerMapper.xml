<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quant.trading.system.mapper.trading.TradingBrokerMapper">

    <resultMap type="com.quant.trading.system.domain.trading.TradingBroker" id="TradingBrokerResult">
        <id     property="brokerId"     column="broker_id"      />
        <result property="brokerName"    column="broker_name"    />
        <result property="brokerCode"    column="broker_code"    />
        <result property="apiKey"        column="api_key"        />
        <result property="secretKey"     column="secret_key"     />
        <result property="brokerType"    column="broker_type"    />
        <result property="status"        column="status"         />
        <result property="remark"       column="remark"         />
        <result property="createTime"   column="create_time"    />
        <result property="updateTime"   column="update_time"    />
    </resultMap>

    <sql id="selectTradingBrokerVo">
        select broker_id, broker_name, broker_code, api_key, secret_key, broker_type, status, remark, create_time, update_time
        from trading_broker
    </sql>

    <select id="selectTradingBrokerList" parameterType="com.quant.trading.system.domain.trading.TradingBroker" resultMap="TradingBrokerResult">
        <include refid="selectTradingBrokerVo"/>
        <where>
            <if test="brokerName != null and brokerName != ''">
                AND broker_name like concat('%', #{brokerName}, '%')
            </if>
            <if test="brokerCode != null and brokerCode != ''">
                AND broker_code like concat('%', #{brokerCode}, '%')
            </if>
            <if test="brokerType != null and brokerType != ''">
                AND broker_type = #{brokerType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectTradingBrokerById" parameterType="Long" resultMap="TradingBrokerResult">
        <include refid="selectTradingBrokerVo"/>
        where broker_id = #{brokerId}
    </select>

    <select id="selectTradingBrokerByCode" parameterType="String" resultMap="TradingBrokerResult">
        <include refid="selectTradingBrokerVo"/>
        where broker_code = #{brokerCode}
    </select>

    <insert id="insertTradingBroker" parameterType="com.quant.trading.system.domain.trading.TradingBroker" useGeneratedKeys="true" keyProperty="brokerId">
        insert into trading_broker
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="brokerName != null and brokerName != ''">broker_name,</if>
            <if test="brokerCode != null and brokerCode != ''">broker_code,</if>
            <if test="apiKey != null and apiKey != ''">api_key,</if>
            <if test="secretKey != null and secretKey != ''">secret_key,</if>
            <if test="brokerType != null and brokerType != ''">broker_type,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="brokerName != null and brokerName != ''">#{brokerName},</if>
            <if test="brokerCode != null and brokerCode != ''">#{brokerCode},</if>
            <if test="apiKey != null and apiKey != ''">#{apiKey},</if>
            <if test="secretKey != null and secretKey != ''">#{secretKey},</if>
            <if test="brokerType != null and brokerType != ''">#{brokerType},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            now(),
        </trim>
    </insert>

    <update id="updateTradingBroker" parameterType="com.quant.trading.system.domain.trading.TradingBroker">
        update trading_broker
        <trim prefix="SET" suffixOverrides=",">
            <if test="brokerName != null and brokerName != ''">broker_name = #{brokerName},</if>
            <if test="brokerCode != null and brokerCode != ''">broker_code = #{brokerCode},</if>
            <if test="apiKey != null and apiKey != ''">api_key = #{apiKey},</if>
            <if test="secretKey != null and secretKey != ''">secret_key = #{secretKey},</if>
            <if test="brokerType != null and brokerType != ''">broker_type = #{brokerType},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now(),
        </trim>
        where broker_id = #{brokerId}
    </update>

    <delete id="deleteTradingBrokerById" parameterType="Long">
        delete from trading_broker where broker_id = #{brokerId}
    </delete>

    <delete id="deleteTradingBrokerByIds" parameterType="Long">
        delete from trading_broker where broker_id in
        <foreach item="brokerId" collection="array" open="(" separator="," close=")">
            #{brokerId}
        </foreach>
    </delete>

    <select id="checkBrokerCodeUnique" parameterType="String" resultType="int">
        select count(1) from trading_broker where broker_code = #{brokerCode}
    </select>

</mapper>
