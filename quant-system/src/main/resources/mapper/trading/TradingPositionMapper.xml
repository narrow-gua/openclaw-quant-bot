<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quant.trading.system.mapper.trading.TradingPositionMapper">

    <resultMap type="com.quant.trading.system.domain.trading.TradingPosition" id="TradingPositionResult">
        <id     property="positionId"       column="position_id"         />
        <result property="stockId"         column="stock_id"           />
        <result property="symbol"           column="symbol"            />
        <result property="stockName"        column="stock_name"         />
        <result property="brokerId"         column="broker_id"          />
        <result property="brokerName"       column="broker_name"        />
        <result property="positionType"     column="position_type"     />
        <result property="quantity"         column="quantity"           />
        <result property="avgPrice"         column="avg_price"         />
        <result property="currentPrice"     column="current_price"      />
        <result property="stopLossPrice"    column="stop_loss_price"   />
        <result property="takeProfitPrice"  column="take_profit_price" />
        <result property="totalCost"        column="total_cost"        />
        <result property="marketValue"       column="market_value"      />
        <result property="profitLoss"       column="profit_loss"       />
        <result property="profitLossRate"   column="profit_loss_rate"  />
        <result property="status"           column="status"            />
        <result property="openTime"          column="open_time"         />
        <result property="closeTime"        column="close_time"        />
        <result property="remark"           column="remark"           />
        <result property="createTime"        column="create_time"      />
        <result property="updateTime"       column="update_time"      />
    </resultMap>

    <sql id="selectTradingPositionVo">
        select position_id, stock_id, symbol, stock_name, broker_id, broker_name, position_type, 
               quantity, avg_price, current_price, stop_loss_price, take_profit_price,
               total_cost, market_value, profit_loss, profit_loss_rate, status, 
               open_time, close_time, remark, create_time, update_time
        from trading_position
    </sql>

    <select id="selectTradingPositionList" parameterType="com.quant.trading.system.domain.trading.TradingPosition" resultMap="TradingPositionResult">
        <include refid="selectTradingPositionVo"/>
        <where>
            <if test="symbol != null and symbol != ''">
                AND symbol like concat('%', #{symbol}, '%')
            </if>
            <if test="stockName != null and stockName != ''">
                AND stock_name like concat('%', #{stockName}, '%')
            </if>
            <if test="brokerId != null">
                AND broker_id = #{brokerId}
            </if>
            <if test="positionType != null and positionType != ''">
                AND position_type = #{positionType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by open_time desc
    </select>

    <select id="selectTradingPositionById" parameterType="Long" resultMap="TradingPositionResult">
        <include refid="selectTradingPositionVo"/>
        where position_id = #{positionId}
    </select>

    <select id="selectTradingPositionBySymbol" resultMap="TradingPositionResult">
        <include refid="selectTradingPositionVo"/>
        where symbol = #{symbol}
        <if test="brokerId != null">
            AND broker_id = #{brokerId}
        </if>
        <if test="positionType != null and positionType != ''">
            AND position_type = #{positionType}
        </if>
        AND status = 'OPEN'
        limit 1
    </select>

    <select id="selectOpenPositions" resultMap="TradingPositionResult">
        <include refid="selectTradingPositionVo"/>
        where status = 'OPEN'
        order by open_time desc
    </select>

    <insert id="insertTradingPosition" parameterType="com.quant.trading.system.domain.trading.TradingPosition" useGeneratedKeys="true" keyProperty="positionId">
        insert into trading_position
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="stockId != null">stock_id,</if>
            <if test="symbol != null and symbol != ''">symbol,</if>
            <if test="stockName != null and stockName != ''">stock_name,</if>
            <if test="brokerId != null">broker_id,</if>
            <if test="brokerName != null and brokerName != ''">broker_name,</if>
            <if test="positionType != null and positionType != ''">position_type,</if>
            <if test="quantity != null">quantity,</if>
            <if test="avgPrice != null">avg_price,</if>
            <if test="currentPrice != null">current_price,</if>
            <if test="stopLossPrice != null">stop_loss_price,</if>
            <if test="takeProfitPrice != null">take_profit_price,</if>
            <if test="totalCost != null">total_cost,</if>
            <if test="marketValue != null">market_value,</if>
            <if test="profitLoss != null">profit_loss,</if>
            <if test="profitLossRate != null">profit_loss_rate,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="openTime != null">open_time,</if>
            <if test="remark != null">remark,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="stockId != null">#{stockId},</if>
            <if test="symbol != null and symbol != ''">#{symbol},</if>
            <if test="stockName != null and stockName != ''">#{stockName},</if>
            <if test="brokerId != null">#{brokerId},</if>
            <if test="brokerName != null and brokerName != ''">#{brokerName},</if>
            <if test="positionType != null and positionType != ''">#{positionType},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="avgPrice != null">#{avgPrice},</if>
            <if test="currentPrice != null">#{currentPrice},</if>
            <if test="stopLossPrice != null">#{stopLossPrice},</if>
            <if test="takeProfitPrice != null">#{takeProfitPrice},</if>
            <if test="totalCost != null">#{totalCost},</if>
            <if test="marketValue != null">#{marketValue},</if>
            <if test="profitLoss != null">#{profitLoss},</if>
            <if test="profitLossRate != null">#{profitLossRate},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="openTime != null">#{openTime},</if>
            <if test="remark != null">#{remark},</if>
            now(),
        </trim>
    </insert>

    <update id="updateTradingPosition" parameterType="com.quant.trading.system.domain.trading.TradingPosition">
        update trading_position
        <trim prefix="SET" suffixOverrides=",">
            <if test="stockId != null">stock_id = #{stockId},</if>
            <if test="symbol != null and symbol != ''">symbol = #{symbol},</if>
            <if test="stockName != null and stockName != ''">stock_name = #{stockName},</if>
            <if test="brokerId != null">broker_id = #{brokerId},</if>
            <if test="brokerName != null and brokerName != ''">broker_name = #{brokerName},</if>
            <if test="positionType != null and positionType != ''">position_type = #{positionType},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="avgPrice != null">avg_price = #{avgPrice},</if>
            <if test="currentPrice != null">current_price = #{currentPrice},</if>
            <if test="stopLossPrice != null">stop_loss_price = #{stopLossPrice},</if>
            <if test="takeProfitPrice != null">take_profit_price = #{takeProfitPrice},</if>
            <if test="totalCost != null">total_cost = #{totalCost},</if>
            <if test="marketValue != null">market_value = #{marketValue},</if>
            <if test="profitLoss != null">profit_loss = #{profitLoss},</if>
            <if test="profitLossRate != null">profit_loss_rate = #{profitLossRate},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="openTime != null">open_time = #{openTime},</if>
            <if test="closeTime != null">close_time = #{closeTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now(),
        </trim>
        where position_id = #{positionId}
    </update>

    <delete id="deleteTradingPositionById" parameterType="Long">
        delete from trading_position where position_id = #{positionId}
    </delete>

    <delete id="deleteTradingPositionByIds" parameterType="Long">
        delete from trading_position where position_id in
        <foreach item="positionId" collection="array" open="(" separator="," close=")">
            #{positionId}
        </foreach>
    </delete>

</mapper>
